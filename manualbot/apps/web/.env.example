# ManualBot Web Environment Configuration
# Copy this file to .env.local:
#   cp .env.example .env.local

# ─── API ──────────────────────────────────────────────────────────────────────
# URL of the ManualBot API server
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Widget ───────────────────────────────────────────────────────────────────
# URL where the widget.js is served from
NEXT_PUBLIC_WIDGET_URL=http://localhost:8000
