# ManualBot API Environment Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME=ManualBot
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=development

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://manualbot:manualbot@localhost:5432/manualbot
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ─── Redis / Celery ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── Qdrant Vector DB ─────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=manualbot

# ─── Storage ──────────────────────────────────────────────────────────────────
# Options: "local" or "s3"
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=/tmp/manualbot/uploads

# S3 / MinIO (only needed if STORAGE_BACKEND=s3)
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=

# ─── AI Providers ─────────────────────────────────────────────────────────────
# Required: Your OpenAI API key
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

CHAT_PROVIDER=openai
CHAT_MODEL=gpt-4.1-mini

# ─── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=150
MAX_CHUNKS_PER_QUERY=6

# ─── File Upload ──────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=50

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
CORS_ALLOW_CREDENTIALS=true

# ─── Widget ───────────────────────────────────────────────────────────────────
WIDGET_CDN_URL=http://localhost:3001

# ─── Logging ──────────────────────────────────────────────────────────────────
# Options: "json" or "console"
LOG_LEVEL=INFO
LOG_FORMAT=json
